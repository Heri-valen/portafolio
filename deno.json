{
  "lock": false,
  "tasks": {
    "start": "deno run -A --watch=static/,routes/,components/,islands/,content/ main.ts",
    "build": "deno run -A main.ts",
    "preview": "deno run -A main.ts"
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "fresh": "jsr:@fresh/core@2.3.3",
    "fresh/": "jsr:@fresh/core@2.3.3/",
    "preact": "npm:preact@10.25.4",
    "@preact/signals": "npm:@preact/signals@2.9.4",
    "$std/": "jsr:@std@0.224.0/",
    "animejs": "npm:animejs@3.2.2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
