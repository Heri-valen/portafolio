{
  "lock": false,
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check **/*.ts && deno check **/*.tsx",
    "start": "deno run -A --watch=static/,routes/ main.ts",
    "build": "deno run -A main.ts",
    "preview": "deno run -A main.ts",
    "update": "deno run -Ar jsr:@fresh/update"
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@2.3.3/",
    "preact": "https://esm.sh/preact@10.25.4",
    "preact/": "https://esm.sh/preact@10.25.4/",
    "@preact/signals": "https://esm.sh/@preact/signals@1.3.2",
    "@preact/signals-core": "https://esm.sh/@preact/signals-core@1.3.2",
    "tailwindcss": "https://esm.sh/tailwindcss@3.4.17",
    "$std/": "https://deno.land/std@0.224.0/",
    "animejs": "https://esm.sh/animejs@3.2.2"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve"
  }
}
